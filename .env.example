# sbj-website 环境变量样板。本地开发复制为 .env.local 后填值。
# .env / .env.local 已在 .gitignore，绝不要提交。

# ---------- 数据库 ----------
# 本地用 docker postgres，生产换腾讯云 CDB 华东（上海）
DATABASE_URL="postgresql://sbj:sbj_dev_pwd@localhost:5432/sbj_dev?schema=public"

# ---------- 字段加密（INF-04）----------
# 32 字节 base64。生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=

# ---------- Admin 认证（INF-06，CRM-02）----------
# bcrypt hash，生成方式：node -e "require('bcryptjs').hash('your-password', 12).then(h => console.log(Buffer.from(h).toString('base64')))"
ADMIN_PASSWORD_HASH=
# iron-session 密钥，≥32 字符，生成方式：node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
ADMIN_SESSION_PASSWORD=

# ---------- LLM 三家（INF-03）----------
# DeepSeek 主
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 豆包（火山引擎方舟）备 1
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=

# 讯飞星火 备 2
IFLYTEK_API_KEY=
IFLYTEK_BASE_URL=https://spark-api-open.xf-yun.com/v1
IFLYTEK_MODEL=4.0Ultra

# ---------- 测试 ----------
# E2E 跑 mock 模式时，LLM 调用走 lib/mocks/llm-mocks.ts 不真调
E2E_MOCK_MODE=false
